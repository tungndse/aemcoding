<?xml version="1.0" encoding="UTF-8"?>
<jcr:root xmlns:sling="http://sling.apache.org/jcr/sling/1.0" xmlns:cq="http://www.day.com/jcr/cq/1.0"
          xmlns:jcr="http://www.jcp.org/jcr/1.0" xmlns:nt="http://www.jcp.org/jcr/nt/1.0"
          jcr:primaryType="cq:Page">
    <jcr:content
            cq:template="/conf/aemcoding/settings/wcm/templates/tutorial-page-template"
            jcr:primaryType="cq:PageContent"
            sling:resourceType="aemcoding/components/page">
        <root
                jcr:primaryType="nt:unstructured"
                sling:resourceType="aemcoding/components/container"
                layout="responsiveGrid">
            <container
                    jcr:primaryType="nt:unstructured"
                    sling:resourceType="aemcoding/components/container"
                    layout="responsiveGrid">
                <tutorialbanner
                        jcr:primaryType="nt:unstructured"
                        sling:resourceType="aemcoding/components/tutorialbanner"
                        label="Tutorial"
                        title="Welcome to the tutorial page"
                        description="This page helps explain the current page structure and runtime information"/>
                <tutorialpageinfo
                        jcr:primaryType="nt:unstructured"
                        sling:resourceType="aemcoding/components/tutorialpageinfo"/>
            </container>
        </root>
    </jcr:content>
</jcr:root>
